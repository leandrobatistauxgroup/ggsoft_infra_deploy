# =============================================================
# GGSoft - Configuração de Deploy
# 1. Copie este arquivo: cp ggsoft.env.example ggsoft.env
# 2. Preencha APENAS os valores marcados com ALTERE_
# 3. Execute: make deploy
# =============================================================

# ----- Identidade / Location -----
LOCATION=GGSoft

# ----- MySQL (apenas senha e usuário mudam) -----
MYSQL_USER=ALTERE_usuario_mysql
MYSQL_PASSWORD=ALTERE_senha_mysql

# ----- Redis (apenas senha muda) -----
REDIS_PORT=36380
REDIS_PASSWORD=ALTERE_senha_redis

# ----- CS - chave secreta da aplicação -----
CS_SECRET_KEY=ALTERE_chave_secreta_cs

# ----- History - chave de API -----
HISTORY_SECRET_KEY=ALTERE_chave_secreta_history
