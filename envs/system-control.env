# =============================================================================
# System Control - Painel de controle
# =============================================================================

# Path ABSOLUTO do workspace no host (onde ficam todos os repos GGSoft)
# Exemplos:
#   Linux/Mac: /home/ubuntu/ggsoft  ou  /Users/seuuser/workspace/ggsoft
#   Windows: C:\Users\seuuser\workspace\ggsoft
# O Makefile do deploy exporta WORKSPACE_DIR automaticamente.
# Se vazio, o docker-compose usa default.
WORKSPACE_DIR=${WORKSPACE_DIR}

# IP do servidor para URLs externas (NÃO usar localhost)
# Usado pelo painel para gerar links de jogos: http://SERVER_IP:8001/games/...
SERVER_IP=10.10.42.144

# Porta do painel (host bind em 127.0.0.1)
PANEL_PORT=2555

# Senha do Redis (mesmo valor do redis.env)
REDIS_PASSWORD='oTzO04t5T6IkLap3w000WIBt'

# Credenciais do MySQL (para recreditar saldo de teste)
MYSQL_USER=ggsoft_user
MYSQL_PASSWORD='Qe3iyFMcitu45eSOigRKkbHVZ3C3TG1O'

# Token do usuário de teste (is_test=1) - Pinger
RGS_TOKEN=TK15

# Token de segundo usuário de teste - Circuit
